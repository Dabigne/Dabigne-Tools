<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Module.WorkShopTools.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Module.WorkShopTools.Views.ModeExplorerView"
             x:DataType="viewModels:ModeExplorerViewModel">

    <Design.DataContext>
        <viewModels:ModeExplorerViewModel/>    
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="Url length" VerticalAlignment="Center"/>
            <TextBox Text="{Binding UrlLength}"/>
            <TextBlock Text="Remove trailing //" VerticalAlignment="Center"/>
            <CheckBox IsChecked="{Binding RemoveLastSlash}"/>
            <Button Content="Open..."
                    Command="{Binding LoadFileCommand}"/>
            <Button Content="Download"
                    Command="{Binding DownloadCommand}"/>
        </StackPanel>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Urls}"
                 SelectedItem="{Binding SelectedUrl}"/>
    </Grid>
    
</UserControl>
