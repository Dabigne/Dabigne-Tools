<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:Application.Core.Converters"
                    xmlns:userControls="clr-namespace:Application.Core.UserControls">
	<!-- Design time preview -->
	<Design.PreviewWith>
		<StackPanel Width="400" Spacing="10">
			<!-- Force using default Theme Variant -->
			<ThemeVariantScope RequestedThemeVariant="Default">
				<StackPanel Spacing="10" Background="{DynamicResource SystemRegionBrush}">
					<userControls:RatingControl Value="0" MaxValue="5"/>
					<userControls:RatingControl Value="2" MaxValue="5"/>
					<userControls:RatingControl Value="6" MaxValue="6" 
					                            Width="150" 
					                            HorizontalAlignment="Left"/>
				</StackPanel>
			</ThemeVariantScope>
			<!-- Force using Light Theme Variant -->
			<ThemeVariantScope RequestedThemeVariant="Light">
				<StackPanel Spacing="10" Background="{DynamicResource SystemRegionBrush}">
					<userControls:RatingControl Value="0" MaxValue="5" />
					<userControls:RatingControl Value="2" MaxValue="5" />
					<userControls:RatingControl Value="6" MaxValue="6" Width="150" HorizontalAlignment="Left"/>
				</StackPanel>
			</ThemeVariantScope>
			<!-- Force using Dark Theme Variant -->
			<ThemeVariantScope RequestedThemeVariant="Dark">
				<StackPanel Spacing="10" Background="{DynamicResource SystemRegionBrush}">
					<userControls:RatingControl Value="0" MaxValue="5"/>
					<userControls:RatingControl Value="2" MaxValue="5"/>
					<userControls:RatingControl Value="6" MaxValue="6"/>
				</StackPanel>
			</ThemeVariantScope>
		</StackPanel>
	</Design.PreviewWith>

	<!-- Define the Theme Variants -->
	<ResourceDictionary.ThemeDictionaries>
		<ResourceDictionary x:Key="Default">
			<StreamGeometry x:Key="RatingControlCheckPath">
				m 1 1 a 1 1 0 1 0 0.01 0.01 z
			</StreamGeometry>
			<SolidColorBrush x:Key="RatingControlSelectedBrush" Color="Gold"/>
			<SolidColorBrush x:Key="RatingControlSelectedStrokeBrush" Color="Goldenrod"/>
			<SolidColorBrush x:Key="RatingControlUnselectedBrush" Color="White"/>
			<SolidColorBrush x:Key="RatingControlUnselectedStrokeBrush" Color="Gray"/>
		</ResourceDictionary>
		<ResourceDictionary x:Key="Light">
			<StreamGeometry x:Key="RatingControlCheckPath">
				m 1 1 a 1 1 0 1 0 0.01 0.01 z
			</StreamGeometry>
			<SolidColorBrush x:Key="RatingControlSelectedBrush" Color="Gold"/>
			<SolidColorBrush x:Key="RatingControlSelectedStrokeBrush" Color="DarkGoldenrod"/>
			<SolidColorBrush x:Key="RatingControlUnselectedBrush" Color="White"/>
			<SolidColorBrush x:Key="RatingControlUnselectedStrokeBrush" Color="Gray"/>
		</ResourceDictionary>
		<ResourceDictionary x:Key="Dark">
			<StreamGeometry x:Key="RatingControlCheckPath">
				m 1 1 a 1 1 0 1 0 0.01 0.01 z
			</StreamGeometry>
			<SolidColorBrush x:Key="RatingControlSelectedBrush" Color="Red"/>
			<SolidColorBrush x:Key="RatingControlSelectedStrokeBrush" Color="White"/>
			<SolidColorBrush x:Key="RatingControlUnselectedBrush" Color="Transparent"/>
			<SolidColorBrush x:Key="RatingControlUnselectedStrokeBrush" Color="White"/>
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>
    
    <ControlTheme x:Key="{x:Type userControls:RatingControl}" 
                  TargetType="userControls:RatingControl">
        <ControlTheme.Resources>
            <converters:IsSmallerOrEqualConverter x:Key="IsSmallerOrEqualConverter"/>
        </ControlTheme.Resources>
	    
	    <Setter Property="CheckSize" Value="20"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <ItemsControl x:Name="PART_ChecksPresenter"
                                  ItemsSource="{TemplateBinding Checks}">
                        
                        <ItemsControl.Styles>
                            <Style Selector="Path.check" >
                                <Setter Property="Data" Value="{DynamicResource RatingControlCheckPath}" />
                                <Setter Property="Margin" Value="5" />
                                <Setter Property="Fill" Value="{DynamicResource RatingControlUnselectedBrush}" />
                                <Setter Property="Stroke" Value="{DynamicResource RatingControlUnselectedStrokeBrush}" />
                                <Setter Property="StrokeThickness" Value="2" />
                                <Setter Property="Stretch" Value="Uniform" />
                            </Style>
    
                            <Style Selector="Path.selected" >
                                <Setter Property="Fill" Value="{DynamicResource RatingControlSelectedBrush}" />
                                <Setter Property="Stroke" Value="{DynamicResource RatingControlSelectedStrokeBrush}" />
                            </Style>
    
                            <Style Selector="Path.check:pointerover" >
                                <Setter Property="RenderTransform" Value="scale(1.3)" />
                                <Setter Property="Fill" Value="{DynamicResource RatingControlSelectedStrokeBrush}" />
                            </Style>

                        </ItemsControl.Styles>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Path Classes="check"
                                      Width="{Binding CheckSize, RelativeSource={RelativeSource AncestorType=userControls:RatingControl}}">
                                    <Classes.selected>
                                        <MultiBinding Converter="{StaticResource IsSmallerOrEqualConverter}">
                                            <Binding />
                                            <Binding RelativeSource="{RelativeSource AncestorType=userControls:RatingControl}" 
                                                     Path="Value" />
                                        </MultiBinding>
                                    </Classes.selected>
                                </Path>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </ControlTheme>
</ResourceDictionary>