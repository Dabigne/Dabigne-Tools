<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dabigne.Tools.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Application.Core.Views;assembly=Application.Core"
        mc:Ignorable="d" 
        d:DesignWidth="800" 
        d:DesignHeight="450"
        x:Class="Dabigne.Tools.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Dabigne Tools"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent">
    <Window.Styles>
        <StyleInclude Source="avares://Application.Core/UserControls/TabItemStyle.axaml"/>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="Black"
                    TintOpacity="1"
                    MaterialOpacity="0.65" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <SplitView DisplayMode="CompactInline"
                   IsPaneOpen="{Binding IsPaneOpen}"
                   CompactPaneLength="55"
                   OpenPaneLength="300">
            <SplitView.Pane>
                <Grid RowDefinitions="Auto, *">
                    <Button Grid.Row="0"
                            Content="{Binding PaneButtonContent}"
                            VerticalAlignment="Top"
                            Margin="4"
                            Command="{Binding TogglePaneCommand}"/>
                    <TreeView Grid.Row="1"
                              ItemsSource="{Binding NavigationItems}"
                              SelectedItem="{Binding SelectedItem}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding Title}"/>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>                        
                    </TreeView>
                </Grid>
            </SplitView.Pane>
            <Grid RowDefinitions="2*, 1, *">
                <TabControl Grid.Row="0"
                            Classes="navigation"
                            ItemsSource="{Binding TabItems}"/>
                <GridSplitter Grid.Row="1"
                              ResizeDirection="Rows"
                              Height="2"/>
                <views:OutputView Grid.Row="2"
                                  DataContext="{Binding Output}"/>
            </Grid>
        </SplitView>
        
    </Panel>
</Window>
