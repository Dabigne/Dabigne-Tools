<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Module.PdfTools.ViewModels"
             xmlns:components="clr-namespace:Module.PdfTools.Views.Components"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Module.PdfTools.Views.PdfMergeView">
    
    <UserControl.Resources>
        <ControlTheme x:Key="ButtonTheme"
                      TargetType="Button" 
                      BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </ControlTheme>
    </UserControl.Resources>
    
    <Design.DataContext>
        <viewModels:PdfMergeViewModelDesign/>    
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto,Auto"
          ColumnDefinitions="*,Auto"
          Margin="4">

        <components:FileListView Grid.Row="0"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="2"
                                 DataContext="{Binding FileList}"/>
        
        <Border Grid.Row="1" 
                Grid.Column="0"
                Margin="4"
                CornerRadius="4"
                Background="{DynamicResource TextControlBackground}">
            <TextBlock Text="{Binding MergedPdfPath}"
                       VerticalAlignment="Center"/>
        </Border>
        <Button Grid.Row="1"
                Grid.Column="1"
                Theme="{StaticResource ButtonTheme}"
                Content="Pick target..."
                Command="{Binding PickSaveFileCommand}"/>
        
        <StackPanel Grid.Row="2" 
                    Grid.Column="0"
                    Margin="4"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <TextBlock Text="Page count: "/>
            <TextBlock Text="{Binding PageCount}"/>
        </StackPanel>
        
        <Button Grid.Row="2"
                Grid.Column="1"
                Theme="{StaticResource ButtonTheme}"
                Foreground="{DynamicResource AccentButtonForeground}"
                Background="{DynamicResource AccentButtonBackground}"
                Content="Merge"
                Command="{Binding MergeCommand}"/>
    </Grid>
</UserControl>
