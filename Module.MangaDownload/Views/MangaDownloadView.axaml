<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Module.MangaDownload.ViewModels"
             xmlns:components="clr-namespace:Module.MangaDownload.Views.Components"
             mc:Ignorable="d" 
             d:DesignWidth="800" 
             d:DesignHeight="450"
             x:Class="Module.MangaDownload.Views.MangaDownloadView"
             x:DataType="vm:MangaDownloadViewModel">
    
    <Design.DataContext>
        <vm:DesignTimeMangaDownloadViewModel/>
    </Design.DataContext>

        <Grid Margin="20"
              VerticalAlignment="Center" 
              RowDefinitions="Auto,Auto,Auto">

            <components:MangaSearchControl Grid.Row="0"
                                           DataContext="{Binding SearchViewModel}"/>
            
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  Grid.ColumnSpan="2" 
                  ColumnDefinitions="*,*,*,*">

                <TextBlock Grid.Column="0"
                           Margin="10"
                           Text="From chapter:"/>
                <NumericUpDown Grid.Column="1"
                               Margin="10"
                               FormatString="0"
                               Value="{Binding FirstChapter}"/>
                
                <TextBlock Grid.Column="2"
                           Margin="10"
                           Text="To:"/>
                <NumericUpDown Grid.Column="3"
                               Margin="10"
                               FormatString="0"
                               Value="{Binding LastChapter}"/>
            </Grid>

            <Button Grid.Row="2"
                    Foreground="{DynamicResource AccentButtonForeground}"
                    Background="{DynamicResource AccentButtonBackground}"
                    Margin="10,20"
                    Padding="20, 5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Content="Download"
                    Command="{Binding ProcessCommand}"
                    IsEnabled="{Binding CanDownload}"/>
        </Grid>
</UserControl>
