<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:Module.WarhammerTools.ViewModels.Components"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Module.WarhammerTools.Views.Components.CharacterExpertiseListView">
    
    <UserControl.Styles>
        <StyleInclude Source="avares://Module.WarhammerTools/Styles/CharacterSheetStyle.axaml"/>
        <StyleInclude Source="avares://Application.Core/UserControls/DataGridStyle.axaml"/>
    </UserControl.Styles>

    <Design.DataContext>
        <components:CharacterExpertiseListViewModel/>    
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto"
          Margin="4">
        <TextBlock Grid.Row="0"
                   Classes="title"
                   HorizontalAlignment="Center"
                   Text="COMPETENCES DE BASE"/>
        <DataGrid Grid.Row="1" HorizontalAlignment="Stretch"
                  ItemsSource="{Binding List}"
                  BorderBrush="Gray"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="Gray"
                  VerticalGridLinesBrush="DimGray">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom"
                                    FontSize="10"
                                    Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Car"
                                    FontSize="10"
                                    IsReadOnly="True"
                                    Binding="{Binding Characteristic}"/>
                <DataGridTextColumn Header="Val"
                                    FontSize="10"
                                    IsReadOnly="True"
                                    Binding="{Binding CharacteristicValue}"/>
                <DataGridTemplateColumn Header="Aug">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="components:CharacterExpertiseViewModel">
                            <TextBlock Text="{Binding Improvement, StringFormat='{}{0}'}" 
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center"
                                       FontSize="10"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate DataType="components:CharacterExpertiseViewModel">
                            <NumericUpDown Value="{Binding Improvement}"  
                                           FormatString="N0" 
                                           Minimum="0" 
                                           FontSize="10"
                                           HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Comp"
                                    FontSize="10"
                                    IsReadOnly="True"
                                    Binding="{Binding Value}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>