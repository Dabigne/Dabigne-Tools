<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:Module.WarhammerTools.ViewModels.Components"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Module.WarhammerTools.Views.Components.CharacterMovementView">
    <UserControl.Styles>
        <StyleInclude Source="avares://Module.WarhammerTools/Styles/CharacterSheetStyle.axaml"/>
    </UserControl.Styles>
    
    <Design.DataContext>
        <components:CharacterMovementViewModel/>    
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto"
          ColumnDefinitions="Auto,*,Auto,*,Auto,*">
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6"
                   Text="MOUVEMENT"
                   HorizontalAlignment="Center"/>
        
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Mouvement"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 Text="{Binding Value}"/>
        
        <TextBlock Grid.Row="1" Grid.Column="2"
                   Text="Marche"/>
        <TextBlock Grid.Row="1" Grid.Column="3"
                   Text="{Binding Walk}"/>
        
        <TextBlock Grid.Row="1" Grid.Column="4"
                   Text="Course"/>
        <TextBlock Grid.Row="1" Grid.Column="5"
                   Text="{Binding Run}"/>
 
    </Grid>
    
</UserControl>
