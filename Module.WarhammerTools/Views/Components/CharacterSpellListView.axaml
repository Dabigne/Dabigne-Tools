<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:Module.WarhammerTools.ViewModels.Components"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Module.WarhammerTools.Views.Components.CharacterSpellListView">
    <UserControl.Styles>
        <StyleInclude Source="avares://Module.WarhammerTools/Styles/CharacterSheetStyle.axaml"/>
        <StyleInclude Source="avares://Application.Core/UserControls/DataGridStyle.axaml"/>
    </UserControl.Styles>

    <Design.DataContext>
        <components:CharacterSpellListViewModel/>    
    </Design.DataContext>
    
    <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0"
                   Classes="title"
                   HorizontalAlignment="Center"
                   Text="SORTS ET PRIERES"/>
        
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="+" 
                    HorizontalContentAlignment="Center"
                    Margin="2"
                    Command="{Binding AddCommand}"/>
            <Button Content="-" 
                    HorizontalContentAlignment="Center"
                    Margin="2"
                    Command="{Binding RemoveCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="1" HorizontalAlignment="Stretch"
                  ItemsSource="{Binding List}"
                  SelectedItem="{Binding SelectedItem}"
                  BorderBrush="Gray"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="Gray"
                  VerticalGridLinesBrush="DimGray">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom"
                                    FontSize="10"
                                    Binding="{Binding Name}"/>
                <DataGridTemplateColumn Header="Niv">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="components:CharacterSpellViewModel">
                            <TextBlock Text="{Binding Level, StringFormat='{}{0}'}" 
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center"
                                       FontSize="10"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate DataType="components:CharacterSpellViewModel">
                            <NumericUpDown Value="{Binding Level}"  
                                           FormatString="N0" 
                                           Minimum="0" 
                                           FontSize="10"
                                           HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Portée"
                                    FontSize="10"
                                    Binding="{Binding Range}"/>
                <DataGridTextColumn Header="Cible"
                                    FontSize="10"
                                    Binding="{Binding Target}"/>
                <DataGridTextColumn Header="Durée"
                                    FontSize="10"
                                    Binding="{Binding Duration}"/>
                <DataGridTextColumn Header="Effets"
                                    FontSize="10"
                                    Binding="{Binding Effects}"/>
            </DataGrid.Columns>
            
        </DataGrid>
        
    </Grid>
</UserControl>
