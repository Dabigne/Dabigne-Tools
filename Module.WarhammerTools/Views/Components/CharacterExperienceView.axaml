<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:Module.WarhammerTools.ViewModels.Components"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Module.WarhammerTools.Views.Components.CharacterExperienceView">
    <UserControl.Styles>
        <StyleInclude Source="avares://Module.WarhammerTools/Styles/CharacterSheetStyle.axaml"/>
    </UserControl.Styles>
    
    <Design.DataContext>
        <components:CharacterExperienceViewModel/>    
    </Design.DataContext>
    
    <Grid RowDefinitions="Auto,Auto,Auto"
          ColumnDefinitions="*,*,*">
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                   Classes="title"
                   Text="EXPERIENCE"
                   HorizontalAlignment="Center"/>
        
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Classes="small"
                   Text="Actuelle"/>
        <TextBox Grid.Row="2" Grid.Column="0"
                 Text="{Binding Current}"/>
        
        <TextBlock Grid.Row="1" Grid.Column="1"
                   Classes="small"
                   Text="Dépensée"/>
        <TextBox Grid.Row="2" Grid.Column="1"
                 Text="{Binding Spent}"/>
        
        <TextBlock Grid.Row="1" Grid.Column="2"
                   Classes="small"
                   Text="Totale"/>
        <TextBox Grid.Row="2" Grid.Column="2"
                 Text="{Binding Total}"/>
 
    </Grid>
</UserControl>