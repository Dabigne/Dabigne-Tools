<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:Module.WarhammerTools.ViewModels.Components"
             xmlns:userControls="clr-namespace:Application.Core.UserControls;assembly=Application.Core"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Module.WarhammerTools.Views.Components.CharacterCharacteristicListView"
             x:DataType="components:CharacterCharacteristicListViewModel">
    <UserControl.Styles>
        <StyleInclude Source="avares://Module.WarhammerTools/Styles/CharacterSheetStyle.axaml"/>
    </UserControl.Styles>

    <Design.DataContext>
        <components:CharacterCharacteristicListViewModel/>    
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto">
        <TextBlock Grid.Row="0"
                   Classes="title"
                   Text="CARACTERISTIQUES"
                   HorizontalAlignment="Center"/>
        
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,*"
              HorizontalAlignment="Stretch">
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition SharedSizeGroup="A"/>
                    <RowDefinition SharedSizeGroup="B"/>
                    <RowDefinition SharedSizeGroup="C"/>
                    <RowDefinition SharedSizeGroup="D"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="1"
                           Classes="small"
                           HorizontalAlignment="Right"
                           Text="Initiales"/>
                <TextBlock Grid.Row="2"
                           Classes="small"
                           HorizontalAlignment="Right"
                           Text="Augmentation"/>
                <TextBlock Grid.Row="3"
                           Classes="small"
                           HorizontalAlignment="Right"
                           Text="Courantes"/>
            </Grid>
        
            <userControls:ComponentsControl Grid.Column="1"
                                            Components="{Binding List}"
                                            HorizontalAlignment="Stretch"
                                            IsHorizontal="True">
                <userControls:ComponentsControl.DataTemplates>
                    <DataTemplate DataType="{x:Type components:CharacterCharacteristicViewModel}">
                        <Grid MinWidth="30">
                            <Grid.RowDefinitions>
                                <RowDefinition SharedSizeGroup="A"/>
                                <RowDefinition SharedSizeGroup="B"/>
                                <RowDefinition SharedSizeGroup="C"/>
                                <RowDefinition SharedSizeGroup="D"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0"
                                   Padding="4"
                                   Margin="0"
                                   HorizontalContentAlignment="Center"
                                   Content="{Binding Shortcut}"/>
                            <NumericUpDown Grid.Row="1"
                                           Classes="small"
                                           Margin="0"
                                           HorizontalContentAlignment="Center"
                                           Value="{Binding InitialValue}"/>
                            <NumericUpDown Grid.Row="2" 
                                           Classes="small"
                                           Margin="0"
                                           HorizontalContentAlignment="Center"
                                           Value="{Binding Improvements}"/>
                            <Label Grid.Row="3"
                                   Padding="4,6" 
                                   Margin="0"
                                   HorizontalContentAlignment="Center"
                                   Content="{Binding CurrentValue}"/>
                        </Grid>
                    </DataTemplate>
                </userControls:ComponentsControl.DataTemplates>
            </userControls:ComponentsControl>
        </Grid>
    </Grid>
</UserControl>
