<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:Module.WarhammerTools.ViewModels.Components"
             xmlns:userControls="clr-namespace:Application.Core.UserControls;assembly=Application.Core"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Module.WarhammerTools.Views.Components.CharacterCharacteristicListView">
    <UserControl.Styles>
    </UserControl.Styles>
    
    <StackPanel Orientation="Horizontal">
        <StackPanel>
            <TextBlock Margin="4,30,4,10" 
                       Text="Initiales"/>
            <TextBlock Margin="4,0,4, 10"
                       Text="Augmentation"/>
            <TextBlock Margin="4,0,4, 0"
                       Text="Courantes"/>
        </StackPanel>
        
        <userControls:ComponentsControl Components="{Binding List}"
                                        IsHorizontale="True">
            <userControls:ComponentsControl.DataTemplates>
                <DataTemplate DataType="{x:Type components:CharacterCharacteristicViewModel}">
                    <StackPanel MinWidth="30">
                        <TextBlock HorizontalAlignment="Center"
                                   Margin="4"
                                   Text="{Binding Shortcut}"/>
                        <TextBox HorizontalContentAlignment="Center"
                                 Text="{Binding InitialValue}"/>
                        <TextBox HorizontalContentAlignment="Center"
                                 Text="{Binding Improvements}"/>
                        <TextBlock Margin="4,6" 
                                   HorizontalAlignment="Center"
                                   Text="{Binding CurrentValue}"/>
                    </StackPanel>
                </DataTemplate>
            </userControls:ComponentsControl.DataTemplates>
        </userControls:ComponentsControl>
    </StackPanel>
</UserControl>
