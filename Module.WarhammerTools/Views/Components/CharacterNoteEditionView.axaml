<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:Module.WarhammerTools.ViewModels.Components"
             xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
             mc:Ignorable="d" 
             d:DesignWidth="800" 
             d:DesignHeight="450"
             x:Class="Module.WarhammerTools.Views.Components.CharacterNoteEditionView"
             x:DataType="components:CharacterNoteViewModel">
    <UserControl.Styles>
        <StyleInclude Source="avares://Module.WarhammerTools/Styles/CharacterSheetStyle.axaml"/>
    </UserControl.Styles>

    <Design.DataContext>
        <components:CharacterNoteViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" 
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding EditionWidth, Mode=TwoWay}"/>
            <ColumnDefinition Width="3"/>
            <ColumnDefinition Width="{Binding ViewWidth, Mode=TwoWay}"/>
        </Grid.ColumnDefinitions>
        
        <TextBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                 Text="{Binding Title}"/>
        <ComboBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" 
                  HorizontalAlignment="Right"
                  MaxHeight="14"
                  Margin="2"
                  Background="Goldenrod"
                  ItemsSource="{Binding ViewTypes}"
                  SelectedItem="{Binding ViewType}"/>
        
        <Border Grid.Row="1" Grid.Column="0"
                BorderThickness="1"
                BorderBrush="Gray"
                Padding="2">
            <ScrollViewer>
                <TextBox Text="{Binding Text}"
                         BorderThickness="0"
                         FontFamily="SFMono"
                         AcceptsReturn="True"
                         AcceptsTab="True"/>
            </ScrollViewer>
        </Border>
        
        <GridSplitter Grid.Row="1" Grid.Column="1"
                      Width="3"
                      ResizeDirection="Columns"/>
        
        <Border Grid.Row="1" Grid.Column="2"
                BorderThickness="1"
                BorderBrush="Gray"
                Padding="2">
            <!-- <md:MarkdownScrollViewer Markdown="{Binding Text}"> -->
            <!--     <md:MarkdownScrollViewer.Styles> -->
            <!--         <StyleInclude Source="avares://Module.WarhammerTools/Styles/MarkdownStyles.axaml"/> -->
            <!--     </md:MarkdownScrollViewer.Styles> -->
            <!-- </md:MarkdownScrollViewer> -->
        </Border>
    </Grid>

</UserControl>
