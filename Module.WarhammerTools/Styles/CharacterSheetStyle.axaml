<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:Application.Core.Behaviors;assembly=Application.Core">
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Application.Core/UserControls/TextInput.axaml"/>
                <ResourceInclude Source="avares://Application.Core/UserControls/NumericUpDown.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>
    
    <Style Selector="Border.main">
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="BorderBrush" Value="DimGray"/>
    </Style>
    
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="4, 2"/>
    </Style>

    <Style Selector="TextBlock.title">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="TextBlock.small">
        <Setter Property="FontSize" Value="10"/>
    </Style>

    <Style Selector="Label">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="BorderBrush" Value="Gray"/>        
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Label.small">
        <Setter Property="FontSize" Value="10"/>
    </Style>
    
    <Style Selector="TextBox">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="CaretBrush" Value="Black"/>
        <Setter Property="BorderBrush" Value="Gray"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource TextControlSelectionHighlightColor}"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    
    <Style Selector="TextBox.small">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    
    <Style Selector="NumericUpDown">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="ShowButtonSpinner" Value="False"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>
    
    <Style Selector="NumericUpDown:pointerover">
        <Setter Property="ShowButtonSpinner" Value="True"/>
    </Style>

    <Style Selector="NumericUpDown.small">
        <Setter Property="BorderBrush" Value="Gray"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="MaxHeight" Value="24"/>
    </Style>
    
    <Style Selector="RepeatButton">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="BurlyWood"/>
        <Setter Property="BorderBrush" Value="DarkGoldenrod"/>
        <Setter Property="BorderThickness" Value="1,1,1,2"/>
    </Style>

    <Style Selector="RepeatButton:pointerover /template/ ContentPresenter">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="DarkGoldenrod"/>
        <Setter Property="BorderBrush" Value="BurlyWood"/>
    </Style>
    
    <Style Selector="Button">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="BurlyWood"/>
        <Setter Property="BorderBrush" Value="DarkGoldenrod"/>
        <Setter Property="MinWidth" Value="24"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="1,1,1,2"/>
    </Style>
    
    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="DarkGoldenrod"/>
        <Setter Property="BorderBrush" Value="BurlyWood"/>
    </Style>
    
    <Style Selector="TabItem">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style Selector="TabItem:pointerover /template/ ContentPresenter">
        <Setter Property="Foreground" Value="Gray"/>
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Foreground" Value="Black"/>
    </Style>
    <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
        <Setter Property="Background" Value="DarkGoldenrod"/>
    </Style>
    
    
</Styles>
