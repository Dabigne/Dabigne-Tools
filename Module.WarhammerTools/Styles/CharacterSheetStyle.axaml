<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:Application.Core.Behaviors;assembly=Application.Core">
    
    <Design.PreviewWith>
        <Border Padding="20">
            <!-- Add Controls for Previewer Here -->
        </Border>
    </Design.PreviewWith>

    <Style Selector="Grid.labelInput">
        <Setter Property="behaviors:ColumnDefinitionsSetter.ColumnDefinitions">
            <ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </ColumnDefinitions>
        </Setter>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    
    <Style Selector="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="4, 2"/>
    </Style>
    
    <Style Selector="TextBox.small">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="MinHeight" Value="22"></Setter>
        <Setter Property="Height" Value="22"/>
        <Setter Property="MaxHeight" Value="22"/>
        <Setter Property="Padding" Value="4,2"></Setter>
        <Setter Property="Margin" Value="4, 2"/>
    </Style>
    
</Styles>
